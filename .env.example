# Copy to .env and fill with values from Supabase → Project Settings → API
# Never commit .env or the service_role key.
#
# Supabase auth URLs for this site (paste in Dashboard → Authentication → URL configuration):
#   Site URL:     https://balticcaretravel.vercel.app
#   Redirects:    https://balticcaretravel.vercel.app/login.html
#                 http://localhost:3000/login.html
# Optional for Vercel branch previews: https://*.vercel.app/**

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
